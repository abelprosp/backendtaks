# Ambiente
NODE_ENV=development
PORT=4000

# Frontend autorizado no CORS (aceita lista separada por vírgula)
FRONTEND_URL=http://localhost:3000
# Compatibilidade com a configuração antiga
FRONTEND_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
# Opcional no backend; mantido para referência e integrações auxiliares
SUPABASE_ANON_KEY=sua-chave-anonima
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Postgres do Supabase (Prisma/schema e consultas diretas)
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.seu-projeto.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[SUA-SENHA]@db.seu-projeto.supabase.co:5432/postgres

# Auth JWT
JWT_SECRET=troque-essa-chave
JWT_REFRESH_SECRET=troque-essa-chave-tambem
JWT_EXPIRES_IN=30d
REFRESH_EXPIRES_IN=365d

# Storage / arquivos
SUPABASE_STORAGE_BUCKET=demandas-anexos
UPLOAD_DIR=./uploads

# IA (opcional)
OPENAI_API_KEY=

# Scripts auxiliares locais
API_URL=http://localhost:4000
